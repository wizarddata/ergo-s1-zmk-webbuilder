# Server config
PORT=8090
APP_BASE_URL=http://localhost:8090
ENABLE_DEV_SERVER=

# Local Docker build (all optional — defaults shown)
# Cache volume holds ZMK fork + zephyr + modules + intermediate build outputs.
# Lives inside Docker engine (~7-10x faster than a bind mount on Windows/Mac).
# BUILD_CACHE_VOLUME=ergo-s1-cache

# Where final .uf2 files land on the host (browsable from your file manager).
# Default on Windows: %LOCALAPPDATA%/ergo-s1-builder/artifacts
# Default elsewhere:  ~/.cache/ergo-s1-builder/artifacts
# ARTIFACTS_DIR=

# ZMK fork (matches arcanemachine's shields). Pinned by default to a vetted
# commit so upstream changes don't silently affect your firmware. Override
# with another commit SHA or branch name to track newer/older revs.
# ZMK_FORK_GIT_URL=https://github.com/arcanemachine/zmk-ergo-s-1.git
# ZMK_FORK_REVISION=f195533d3aeef918f6a81d13e3e4cab17ed9929e

# Docker image (matches Zephyr v4.1.0+zmk-fixes pin in arcanemachine's west.yml)
# DOCKER_IMAGE=zmkfirmware/zmk-dev-arm:4.1-branch
