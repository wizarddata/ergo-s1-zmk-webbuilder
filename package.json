{
  "name": "ergo-s1-zmk-builder",
  "version": "0.2.0",
  "description": "Local-deploy webapp for ErgoS1 ZMK keymap GUI + Docker firmware builds. No GitHub required.",
  "main": "index.js",
  "scripts": {
    "postinstall": "cd app && npm install",
    "start": "node index.js",
    "dev": "cross-env ENABLE_DEV_SERVER=true node index.js",
    "reset-cache": "node -e \"require('./api/services/zmk/west-cache').resetCache().then(()=>console.log('cache volume removed'))\"",
    "sync-defaults": "node scripts/sync-defaults.js",
    "test": "node --check index.js && for f in api/*.js api/routes/*.js api/services/*.js api/services/zmk/*.js; do node --check \"$f\" || exit 1; done"
  },
  "license": "MIT",
  "dependencies": {
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^10.0.0",
    "express": "^4.17.1",
    "lodash": "^4.17.21",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "eslint": "^8.14.0",
    "eslint-config-standard": "^17.0.0"
  }
}
